datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Role: "USER" | "ADMIN"

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  image       String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String      @db.Text
  price           Float
  oldPrice        Float?
  stock           Int         @default(0)
  images          String      // JSON string array of URLs
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  orderItems      OrderItem[]
  isFreeShipping  Boolean     @default(false)
  isNew           Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String
  customerCity    String
  status          String      @default("PENDING")
  cargoNo         String?     @default("")
  totalAmount     Float
  discountAmount  Float       @default(0)
  shippingCost    Float       @default(0)
  couponCode      String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  discount  Float
  type      String   // "percentage" | "fixed"
  expiry    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String   @id @default("current")
  siteName        String   @default("Arı Hayat")
  siteDescription String?  @default("Doğal Bal, Propolis ve Arı Ürünleri")
  contactEmail    String?  @default("destek@arihayat.com")
  contactPhone    String?  @default("0536 341 19 84")
  address         String?
  whatsappNumber  String?
  facebookUrl     String?
  instagramUrl    String?
  twitterUrl      String?
  logoUrl         String?
  announcementBar String?
  isMaintenance   Boolean  @default(false)
  googleAnalyticsId String?
  facebookPixelId   String?
  smtpHost         String?
  smtpPort         Int?
  smtpUser         String?
  smtpPass         String?
  smtpFrom         String?
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  image       String?
  author      String   @default("Arı Hayat")
  category    String?  @default("Genel")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Slider {
  id          String   @id @default(cuid())
  title       String?
  subtitle    String?
  image       String
  buttonText  String?
  buttonLink  String?  @default("/urunler")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CustomPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  comment     String   @db.Text
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String   @default("Genel")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
